# Core roles
APP_ROLE=bot
# roles: bot | worker | watcher | standalone
LOG_LEVEL=INFO
TELEGRAM_MODE=auto

# Telegram strict auth
TELEGRAM_TOKEN=put_your_bot_token_here
TELEGRAM_ALLOWED_USER_ID=123456789
# optional multi-tenant list (comma-separated), example:
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TENANT_MODE=single

# Webhook mode (used when TELEGRAM_MODE=webhook, or TELEGRAM_MODE=auto with WEBHOOK_BASE_URL set)
WEBHOOK_BASE_URL=
WEBHOOK_BIND_HOST=0.0.0.0
WEBHOOK_BIND_PORT=8082
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET_TOKEN=replace_with_long_random_secret_token

# Mini App (optional, enables deep-links and WebApp CTA buttons from bot replies)
MINI_APP_BASE_URL=

# Gemini models (embeddings + grounded answer)
GEMINI_API_KEY=put_gemini_api_key_here
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_GENERATION_MODEL=gemini-2.5-flash

# Storage boundaries
VAULT_PATH=/data/vault
STATE_DIR=/srv/obsidian-bot/state
CACHE_DIR=/srv/obsidian-bot/cache
INDEX_DIR=/srv/obsidian-bot/index

# Worker settings
WORKER_POLL_SECONDS=2
WORKER_RECOVERY_INTERVAL_SECONDS=30
WORKER_STUCK_TIMEOUT_SECONDS=600
WATCHER_POLL_SECONDS=2
JOB_MAX_RETRIES=5

# Google Drive integration (optional)
GDRIVE_ENABLED=false
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_ROOT_FOLDER_ID=
GDRIVE_SHARE_PUBLIC_LINKS=false
GDRIVE_VAULT_MIRROR_INTERVAL_SECONDS=1800
GDRIVE_DB_SNAPSHOT_INTERVAL_SECONDS=86400

# Health endpoints
BOT_HEALTH_PORT=8080
WORKER_HEALTH_PORT=8081

# CouchDB (for Obsidian LiveSync)
COUCHDB_URL=http://couchdb:5984
COUCHDB_USER=obsidian
COUCHDB_PASSWORD=change_me
COUCHDB_DATABASE=obsidian

# Cloudflare Tunnel (optional, use: docker compose --profile remote up -d cloudflared)
CF_TUNNEL_TOKEN=

# Optional crash alert webhook (used by systemd OnFailure unit)
ALERT_WEBHOOK_URL=
